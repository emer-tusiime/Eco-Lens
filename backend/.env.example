# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/ecolens_dev

# JWT
JWT_SECRET=ecolens-super-secret-change-in-production
JWT_EXPIRATION=7d

# Africa's Talking Airtime API
AT_USERNAME=sandbox
AT_API_KEY=your-sandbox-api-key-here
AT_CURRENCY_CODE=UGX

# Rewards
POINTS_PER_DISPOSAL=50
POINTS_TO_UGX_RATE=5
MIN_REDEMPTION_POINTS=100

# CORS
CORS_ORIGIN=*
